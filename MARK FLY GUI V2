-- [[ SISTEMA DE ARRASTE (DRAGGABLE) ]] --
local function makeDraggable(guiObj, targetFrame)
    local dragging, dragInput, dragStart, startPos
    guiObj.InputBegan:Connect(function(input)
        if targetFrame == ButtonFrame and flying then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = targetFrame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    guiObj.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            targetFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

makeDraggable(MainBtn, ButtonFrame)
makeDraggable(IconButton, IconButton)

-- [[ LÓGICA DO BOTÃO MESTRE (CLIQUE DUPLO E TOGGLE) ]] --
local lastClick = 0
IconButton.MouseButton1Click:Connect(function()
    local now = tick()
    if now - lastClick < 0.35 then
        Assets:Destroy()
        return
    end
    lastClick = now
    ButtonFrame.Visible = not ButtonFrame.Visible
end)

-- [[ ANALÓGICO INVISÍVEL ]] --
local AnalogBase = Instance.new("Frame", Assets)
AnalogBase.Size = UDim2.new(0, 220, 0, 220)
AnalogBase.Position = UDim2.new(0.05, 0, 0.58, 0)
AnalogBase.BackgroundTransparency = 1; AnalogBase.Visible = false

AnalogBase.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) and not activeTouch then
        activeTouch = input
    end
end)

UIS.InputChanged:Connect(function(input)
    if input == activeTouch then
        local basePos = AnalogBase.AbsolutePosition + (AnalogBase.AbsoluteSize / 2)
        local inputPos = Vector2.new(input.Position.X, input.Position.Y)
        local diff = inputPos - basePos
        if diff.Magnitude > 10 then
            local dir = diff.Unit
            moveVector = Vector3.new(dir.X, 0, dir.Y)
        else
            moveVector = Vector3.new(0,0,0)
        end
    end
end)

UIS.InputEnded:Connect(function(input)
    if input == activeTouch then activeTouch = nil; moveVector = Vector3.new(0, 0, 0) end
end)

-- [[ SISTEMA DE ANIMAÇÃO (SEM LÓGICA DE FREEZE) ]] --
local currentTrack = nil
local lastAnimId = nil

local function PlayUniversalAnim(animData)
    local char = plr.Character
    if not char or not char:FindFirstChild("Humanoid") then return end
    local animIdStr = "rbxassetid://"..tostring(animData.id)
    if lastAnimId == animIdStr then return end
    lastAnimId = animIdStr
    if currentTrack then currentTrack:Stop(0.3) end
    local success, asset = pcall(function() return game:GetObjects(animIdStr)[1] end)
    if success and asset and asset:IsA("Animation") then
        currentTrack = char.Humanoid:LoadAnimation(asset)
    else
        local animObj = Instance.new("Animation"); animObj.AnimationId = animIdStr
        currentTrack = char.Humanoid:LoadAnimation(animObj)
    end
    if currentTrack then
        currentTrack.Priority = animData.priority
        currentTrack:Play(0.3); currentTrack:AdjustSpeed(animData.speed)
    end
end

-- [[ LÓGICA DE VOO ]] --
local function StartFly()
    local char = plr.Character
    if not char then return end
    local hrp = char:WaitForChild("HumanoidRootPart")
    local hum = char:WaitForChild("Humanoid")
    local camera = workspace.CurrentCamera
    
    local bg = Instance.new("BodyGyro", hrp); bg.P = 9e4; bg.maxTorque = Vector3.new(9e9, 9e9, 9e9)
    local bv = Instance.new("BodyVelocity", hrp); bv.maxForce = Vector3.new(9e9, 9e9, 9e9)
    
    hum.CameraOffset = Vector3.new(0, 2.5, 0)
    
    task.spawn(function()
        while flying do
            RunService.RenderStepped:Wait()
            if not char or not hrp.Parent then break end
            hum.PlatformStand = true
            local camCF = camera.CFrame
            
            if boostLevel == 0 then currentFlySpeed = 50
            elseif boostLevel == 1 then currentFlySpeed = 160
            elseif boostLevel == 2 then currentFlySpeed = 380
            elseif boostLevel == 3 then currentFlySpeed = 780
            end
            
            local isMoving = moveVector.Magnitude > 0.1
            
            if isMoving and boostLevel == 3 then
                TweenService:Create(camera, TweenInfo.new(0.5), {FieldOfView = 100}):Play()
            else
                TweenService:Create(camera, TweenInfo.new(0.5), {FieldOfView = 70}):Play()
            end
            
            if isMoving then
                local finalDirection = (camCF.LookVector * -moveVector.Z + camCF.RightVector * moveVector.X).Unit
                bv.velocity = finalDirection * currentFlySpeed
                if boostLevel == 0 then PlayUniversalAnim(ANIMS.IDLE)
                elseif boostLevel == 1 then PlayUniversalAnim(ANIMS.WALK)
                else PlayUniversalAnim(ANIMS.RUN) end
            else
                bv.velocity = Vector3.new(0, 0.1, 0)
                PlayUniversalAnim(ANIMS.IDLE)
            end
            bg.CFrame = camCF
        end
        
        TweenService:Create(camera, TweenInfo.new(0.5), {FieldOfView = 70}):Play()
        if hum then hum.CameraOffset = Vector3.new(0, 0, 0) end
        bg:Destroy(); bv:Destroy()
        if char:FindFirstChild("Humanoid") then
            char.Humanoid.PlatformStand = false
            char.Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
        if currentTrack then currentTrack:Stop(0.5) end
        lastAnimId = nil
    end)
end

-- [[ CONTROLES ]] --
MainBtn.MouseButton1Click:Connect(function()
    flying = not flying
    if flying then
        MainBtn.Text = "UNFLY"; BoostBtn.Visible = true; AnalogBase.Visible = true; StartFly()
    else
        MainBtn.Text = "FLY"; BoostBtn.Visible = false; AnalogBase.Visible = false
        boostLevel = 0; BoostBtn.Text = "BOOST"
    end
end)

