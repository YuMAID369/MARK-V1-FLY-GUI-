-- [[ ESTILIZAÇÃO (PRETO) ]] --
local function styleButton(btn, text, pos)
    btn.Size = UDim2.new(0, 130, 0, 50)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold; btn.TextSize = 22
    btn.ZIndex = 10; btn.BorderSizePixel = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0.5, 0)
    local stroke = Instance.new("UIStroke", btn)
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border; stroke.Thickness = 2.5
    stroke.Color = Color3.fromRGB(50, 50, 50)
end

